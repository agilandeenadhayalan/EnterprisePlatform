# ==============================================
# Smart Mobility & Analytics Platform
# Environment Variables
# ==============================================
# Copy to .env and fill in values:
#   cp .env.example .env

# ── General ──
PLATFORM_NAME=smart-mobility-platform
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── PostgreSQL ──
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=mobility_platform
POSTGRES_USER=mobility
POSTGRES_PASSWORD=mobility_dev_2024

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=

# ── JWT Auth ──
JWT_SECRET_KEY=dev-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Kafka (Phase 2+) ──
KAFKA_BOOTSTRAP_SERVERS=localhost:29094
SCHEMA_REGISTRY_URL=http://localhost:8089

# ── ClickHouse (Phase 3+) ──
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=mobility_analytics
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ── MinIO / S3 (Phase 3+) ──
MINIO_ENDPOINT=localhost:9002
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=mobility-data-lake

# ── MLflow (Phase 4+) ──
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_ARTIFACT_ROOT=s3://mlflow-artifacts

# ── Elasticsearch (Phase 6+) ──
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200

# ── ScyllaDB (Phase 7+) ──
SCYLLADB_HOST=localhost
SCYLLADB_PORT=9042

# ── Prometheus (Phase 5+) ──
PROMETHEUS_PORT=9090
GRAFANA_PORT=3333
JAEGER_PORT=16686

# ── NYC Taxi Data ──
NYC_TAXI_DATA_DIR=./data/raw/nyc-taxi
NYC_TAXI_YEARS=2023
